{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "bg": {
      "type": "string"
    },
    "redirect_from": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scripts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "navlinks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}