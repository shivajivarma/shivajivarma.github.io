---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<h4 class="text-title-large skill-set-title">{title}</h4>
<div class="skill-set">
  <slot />
</div>

<style lang="scss">
  .skill-set-title {
    margin-bottom: var(--spacing-100);
  }

  .skill-set {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-150);
    margin-bottom: var(--spacing-300);
  }
</style>
