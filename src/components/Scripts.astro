---
import { GOATUI_JS_CDN } from "../siteconfig";

interface Props {
  js?: string[];
  scripts?: string[];
}
const { js = [], scripts = [] } = Astro.props;
---

<script is:inline src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"
></script>

<script is:inline src="/assets/js/main.js"></script>

<!-- Core JS Files -->
<script is:inline type="module" src={GOATUI_JS_CDN}></script>

{
  js.map((file) => (
    <script is:inline type="text/javascript" src={`/assets/js/${file}`} />
  ))
}

{scripts.map((src) => <script is:inline type="text/javascript" src={src} />)}
