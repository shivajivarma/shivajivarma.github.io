---
import {
  AUTHOR,
  REPO_URL,
  PRIVACY_URL,
  LICENSE_URL,
  SPONSOR_URL,
  GITHUB_USERNAME,
} from "../siteconfig";
import "../styles/footer.scss";
---

<footer class="footer-with-about">
  <section class="about">
    <div class="about-content">
      <h2 class="text-headline section-title">Shivaji Varma</h2>
      <p class="text-body-large">
        Staff Software Engineer & Architect based in India. I build and scale
        cloud-based applications, contribute to open source, and share what I
        learn along the way.
      </p>
    </div>
  </section>

  <nav class="footer-links" aria-label="Footer links">
    <h2 class="text-title-large section-title">Links</h2>
    <ul class="section-nav-links">
      <li><wc-link href={PRIVACY_URL}>Privacy Policy</wc-link></li>
      <li><wc-link href={LICENSE_URL}>License</wc-link></li>
      <li><wc-link href={SPONSOR_URL} target="_blank">Sponsor</wc-link></li>
    </ul>
  </nav>

  <div class="footer-social-links" aria-label="Social links">
    <h2 class="text-title-large section-title">Social</h2>

    <ul class="section-nav-links">
      <li>
        <wc-icon-button
          variant="outlined"
          color="surface"
          href={`https://twitter.com/${AUTHOR.twitter}`}
          target="_blank"
          aria-label="X (Twitter)"
        >
          <wc-icon name="logo--twitter" provider="carbon"></wc-icon>
        </wc-icon-button>
      </li>
      <li>
        <wc-icon-button
          variant="outlined"
          color="surface"
          href={`https://www.linkedin.com/in/${AUTHOR.linkedin}`}
          target="_blank"
          aria-label="LinkedIn"
        >
          <wc-icon name="logo--linkedin" provider="carbon"></wc-icon>
        </wc-icon-button>
      </li>
      <li>
        <wc-icon-button
          variant="outlined"
          color="surface"
          href={`https://github.com/${AUTHOR.github}`}
          target="_blank"
          aria-label="GitHub"
        >
          <wc-icon name="logo--github" provider="carbon"></wc-icon>
        </wc-icon-button>
      </li>
      <li>
        <wc-icon-button
          variant="outlined"
          color="surface"
          href={`https://youtube.com/c/${AUTHOR.youtube}`}
          target="_blank"
          aria-label="YouTube"
        >
          <wc-icon name="logo--youtube" provider="carbon"></wc-icon>
        </wc-icon-button>
      </li>
      <li>
        <wc-icon-button
          variant="outlined"
          color="surface"
          href={`mailto:${AUTHOR.email}`}
          aria-label="Email"
        >
          <wc-icon name="email" provider="carbon"></wc-icon>
        </wc-icon-button>
      </li>
    </ul>
  </div>
</footer>
