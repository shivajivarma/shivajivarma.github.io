---
interface BreadcrumbItem {
  name: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
  currentTitle: string;
}

const { items, currentTitle } = Astro.props;
---

<wc-breadcrumb>
  <wc-breadcrumb-item href="/">Home</wc-breadcrumb-item>
  {
    items.map((item) => (
      <wc-breadcrumb-item href={item.href}>
        {item.name.charAt(0).toUpperCase() + item.name.slice(1)}
      </wc-breadcrumb-item>
    ))
  }
  <wc-breadcrumb-item active>{currentTitle}</wc-breadcrumb-item>
</wc-breadcrumb>
