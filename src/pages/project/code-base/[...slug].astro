---
import Post from '../../../layouts/Post.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('code-base');
  const sorted = [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, index) => {
    const filename = post.id.replace(/\.(html|mdx?|md)$/, '');
    const match = filename.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
    if (!match) return null;
    const [, year, month, day, slug] = match;

    const prevPost = sorted[index - 1];
    const nextPost = sorted[index + 1];

    function makeUrl(p: (typeof sorted)[number]) {
      const f = p.id.replace(/\.(html|mdx?|md)$/, '');
      const m = f.match(/^(\d{4})-(\d{2})-(\d{2})-(.+)$/);
      if (!m) return '#';
      const [, y, mo, d, s] = m;
      return `/project/code-base/${y}/${mo}/${d}/${s}/`;
    }

    return {
      params: { slug: `${year}/${month}/${day}/${slug}` },
      props: {
        post,
        prevPost: prevPost ? { url: makeUrl(prevPost), title: prevPost.data.title } : undefined,
        nextPost: nextPost ? { url: makeUrl(nextPost), title: nextPost.data.title } : undefined,
      },
    };
  }).filter(Boolean);
}

interface Props {
  post: Awaited<ReturnType<typeof getCollection<'code-base'>>>[number];
  prevPost?: { url: string; title: string };
  nextPost?: { url: string; title: string };
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();

const breadcrumbs = [
  { name: 'Project', href: '/project/' },
  { name: 'Code Base', href: '/project/code-base/' },
];
---

<Post
  title={post.data.title}
  description={post.data.description}
  keywords={post.data.keywords}
  tags={post.data.tags}
  date={post.data.date}
  breadcrumbs={breadcrumbs}
  prevPost={prevPost}
  nextPost={nextPost}
  relativePath={`project/code-base/_posts/${post.id}`}
>
  <Content />
</Post>
