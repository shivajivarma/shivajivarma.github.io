---
import DefaultWithBanner from '../../../layouts/DefaultWithBanner.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Authoring from '../../../components/Authoring.astro';
import SideNavMenu from '../../../components/SideNavMenu.astro';
import AdsenseResponsive from '../../../components/AdsenseResponsive.astro';
import Comments from '../../../components/Comments.astro';

const breadcrumbs = [{ name: 'Project', href: '/project/' }];
const date = new Date('2016-01-01');

const navlinks = [
  { name: 'C', url: '/project/code-base/tag/?filter=c' },
  { name: 'Python', url: '/project/code-base/tag/?filter=python' },
  { name: 'Java', url: '/project/code-base/tag/?filter=java' },
  { name: 'JavaScript', url: '/project/code-base/tag/?filter=javascript' },
];
---

<DefaultWithBanner
  title="Code Base"
  description="It is a repository of programs, using which you can analyse, hack and learn basic programming."
  keywords={['data structures', 'algorithms', 'search algorithms', 'sorting algorithms', 'graph', 'linked list', 'tree', 'string']}
>
  <Breadcrumb items={breadcrumbs} currentTitle="Code Base" />
  <Authoring date={date} relativePath="project/_posts/2016-01-01-code-base.html" />
  <div class="project" itemscope itemtype="http://schema.org/Article">
    <div class="row">
      <div id="post-list" class="col-md-9">
        <p class="lead">'<b>Code Base</b>' is a repository contains examples of many popular algorithms and data structures.</p>

        <h3>Data Structures</h3>
        <p>Data structure is a particular way of organizing and storing data in a computer so that it can be accessed and modified efficiently.</p>
        <ul>
          <li>
            <b>Linked Lists</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2018/05/27/singly-linked-list/" title="Singly Linked List">Singly Linked List</a></li>
            </ul>
          </li>
          <li><a class="no-underline" href="/project/code-base/2018/06/01/stack/" title="Stack">Stack</a></li>
        </ul>

        <h3>Algorithms</h3>
        <p>Algorithm is an unambiguous specification of how to solve a class of problems.</p>

        <h4>Algorithms by Topic</h4>
        <ul>
          <li>
            <b>Date</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2017/07/08/leap-year/" title="Leap Year">Leap Year</a></li>
            </ul>
          </li>

          <li>
            <b>Math</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2014/12/28/armstrong-number/" title="Armstrong Number">Armstrong Number</a></li>
              <li><a class="no-underline" href="/project/code-base/2015/01/03/greatest-common-divisor/" title="Greatest Common Divisor">Greatest Common Divisor</a></li>
            </ul>
          </li>

          <li>
            <b>Search</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2015/01/05/binary-search/" title="Binary Search">Binary Search</a></li>
              <li><a class="no-underline" href="/project/code-base/2015/01/05/linear-search/" title="Linear Search">Linear Search</a></li>
            </ul>
          </li>

          <li>
            <b>Sorting</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2014/12/28/bubble-sort/" title="Bubble Sort">Bubble Sort</a></li>
              <li><a class="no-underline" href="/project/code-base/2014/12/28/insertion-sort/" title="Insertion Sort">Insertion Sort</a></li>
              <li><a class="no-underline" href="/project/code-base/2015/01/02/merge-sort/" title="Merge Sort">Merge Sort</a></li>
              <li><a class="no-underline" href="/project/code-base/2015/01/02/quick-sort/" title="Quick Sort">Quick Sort</a></li>
              <li><a class="no-underline" href="/project/code-base/2015/01/02/selection-sort/" title="Selection Sort">Selection Sort</a></li>
            </ul>
          </li>

          <li>
            <b>String</b>
            <ul>
              <li><a class="no-underline" href="/project/code-base/2014/12/28/anagram/" title="Anagram">Anagram</a></li>
              <li><a class="no-underline" href="/project/code-base/2014/12/30/longest-palindrome-substring-length/" title="Longest Palindrome Sub String Length">Longest Palindrome Sub String Length</a></li>
              <li><a class="no-underline" href="/project/code-base/2018/05/27/palindrome/" title="Palindrome">Palindrome</a></li>
              <li><a class="no-underline" href="/project/code-base/2018/05/27/reversing-a-string/" title="Reversing A String">Reversing A String</a></li>
            </ul>
          </li>

          <li>
            <b>Uncategorized</b>
            <ul>
              <li>
                Display Patterns
                <ol type="I">
                  <li><a class="no-underline" href="/project/code-base/2017/10/23/display-patterns/" title="Right Angled Triangle">Right Angled Triangle</a></li>
                  <li><a class="no-underline" href="/project/code-base/2017/10/23/display-patterns/" title="Print Z">Print Z</a></li>
                </ol>
              </li>
              <li><a class="no-underline" href="/project/code-base/2017/10/22/permutations/" title="Permutations">Permutations</a></li>
              <li><a class="no-underline" href="/project/code-base/2018/05/04/spiral-matrix/" title="Spiral Matrix">Spiral Matrix</a></li>
              <li><a class="no-underline" href="/project/code-base/2018/05/10/subsets/" title="Subsets">Subsets</a></li>
              <li><a class="no-underline" href="/project/code-base/2017/10/23/towers-of-hanoi/" title="Towers Of Hanoi">Towers Of Hanoi</a></li>
              <li>
                Networking
                <ol type="I">
                  <li><a class="no-underline" href="/project/code-base/2017/10/23/sockets-server-client-communication/" title="Sockets (Server - Client Communication)">Sockets (Server - Client Communication)</a></li>
                </ol>
              </li>
            </ul>
          </li>
        </ul>

        <p>and more...</p>

        <h3>Contribute</h3>
        <p>Did you find a bug? any way to do it better? please feel free to pull-request it (or) drop a mail at <b><a class="no-underline" href="mailto:contact@shivajivarma.com">contact@shivajivarma.com</a></b> :)</p>
      </div>
      <div class="col-md-3">
        <SideNavMenu title="Tags" categories={navlinks} />
        <hr/>
        <AdsenseResponsive />
      </div>
    </div>
  </div>
  <Comments />
</DefaultWithBanner>
