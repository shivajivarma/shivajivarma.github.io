import "../styles/index.scss";

function jumpingSentence(sentence: string) {
  let len = sentence.length;
  return sentence
    .split(" ")
    .map((word) => {
      return `<div class='jumping-word'>${word
        .split("")
        .map((char, index) => {
          if (char === " ") return char;
          return `<h1 style='z-index:${len--};' class='jumping-text'>${char}</h1>`;
        })
        .join("")}</div>`;
    })
    .join(" ");
}
