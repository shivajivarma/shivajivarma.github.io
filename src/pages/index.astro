---
import Default from '../layouts/Default.astro';
import '../styles/index.scss';
---

<Default
  keywords={['Shivaji Varma About Me', 'Contact Shivaji Varma', 'Shivaji Varma Profile', 'Shivaji Varma Resume', 'personal website', 'programmer', 'software engineering', 'web developer']}
  isRoot={true}
  css={['/assets/css/index.css']}
>

<div class="banner">
  <div class="container">
    <div class="banner-content-section">
      <div class="banner-content">
        <h1 class="text-display">
          Hi, <br/>I'm Shivaji Varma<span class="color-brand">.</span>
        </h1>
        <h2 class="text-title-large">A Polyglot full stack developer from India.</h2>
      </div>
    </div>

    <div class="banner-image-section">
      <img src="/assets/img/profile.webp" height="400" width="400"/>
    </div>
  </div>
</div>

<div class="sections-wrapper">

  <goat-container class="about section">
    <p class="">About<span class="color-brand">.</span></p>
    <div class="bullet-pointer-shock">
      <goat-text expressive>
        Currently working as a Staff Software Engineer, having more than <span class="experience"></span> years
        experience in developing internet-based applications. Contributing to architecture, frontend and backend.
      </goat-text>

      <goat-text expressive>
        Skilled in requirement analysis, design, development, coding, integration, and maintenance of web-based
        applications.
      </goat-text>

      <goat-text expressive>
        Graduated in computer science from
        <goat-link href="https://gitam.edu" target="_blank">GITAM University, Visakhapatnam</goat-link>
        .
      </goat-text>

      <goat-text expressive>
        In my free time I play CS:GO
      </goat-text>
    </div>

    <goat-text expressive><b>Fun fact:</b> You can find my name in the list of
      <goat-link href="https://github.com/jquery/jquery/blob/main/AUTHORS.txt#L257" target="_blank">jQuery authors</goat-link>
      .
    </goat-text>

    <goat-button href="/assets/docs/shivaji-resume-infographic.pdf" target="_blank" icon="download" icon-end>Download
      Resume
    </goat-button>
  </goat-container>

  <goat-container class="skills section">
    <goat-text type="heading" heading-size="5" class="title">Skills<span class="color-brand">.</span></goat-text>
    <goat-text class="skill-set-title">BACKEND END</goat-text>
    <p class="skill-set">
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/java/java-original.svg" title="Java" alt="Java" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/nodejs/nodejs-original.svg" title="NodeJS" alt="NodeJS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/denojs/denojs-original.svg" title="DenoJS" alt="DenoJS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/python/python-original.svg" title="Python" alt="Python" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/php/php-original.svg" title="PHP" alt="PHP" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/c/c-original.svg" title="C" alt="C" width="26px"/>&nbsp;
    </p>

    <goat-text class="skill-set-title">FRONT END</goat-text>
    <p class="skill-set">
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/javascript/javascript-original.svg" title="JavaScript" alt="JavaScript" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons//typescript/typescript-original.svg" title="TypeScript" alt="TypeScript" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/html5/html5-original.svg" title="HTML5" alt="HTML" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/css3/css3-original.svg" title="CSS3" alt="CSS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/sass/sass-original.svg" title="CSS3" alt="CSS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/angularjs/angularjs-original.svg" title="AngularJS" alt="AngularJS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/react/react-original.svg" title="React" alt="React" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/bootstrap/bootstrap-original.svg" title="Bootstrap" alt="Bootstrap" width="26px"/>&nbsp;
    </p>

    <goat-text class="skill-set-title">TOOLS</goat-text>
    <p class="skill-set">
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/mysql/mysql-original.svg" title="MySQL" alt="MySQL" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/mongodb/mongodb-original.svg" title="MongoDB" alt="MongoDB" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/oracle/oracle-original.svg" title="Oracle" alt="Oracle" width="26px"/>&nbsp;
      <img src="/assets/img/skills/servicenow.png" title="ServiceNow" alt="ServiceNow" width="26px" height="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/git/git-original.svg" title="Git" alt="Git" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/azure/azure-original.svg" title="Azure" alt="Azure" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/amazonwebservices/amazonwebservices-original.svg" title="AWS" alt="AWS" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/jenkins/jenkins-original.svg" title="Jenkins" alt="Jenkins" width="26px"/>&nbsp;
    </p>

    <goat-text class="skill-set-title">FRAMEWORKS</goat-text>
    <p class="skill-set">
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/spring/spring-original.svg" title="Spring" alt="Spring" width="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/express/express-original.svg" title="Express" alt="Express" width="26px"/>&nbsp;
    </p>

    <goat-text class="skill-set-title">INTEGRATIONS</goat-text>
    <p class="skill-set">
      <img src="/assets/img/skills/twilio.svg" title="Twilio" alt="Twilio" width="26px" height="26px"/>&nbsp;
      <img src="/assets/img/skills/microsoft-teams.png" title="Microsoft Teams" alt="Microsoft Teams" width="26px" height="26px"/>&nbsp;
      <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/slack/slack-original.svg" title="Slack" alt="Slack" width="26px"/>&nbsp;
    </p>
  </goat-container>

  <goat-container class="experience section">
    <goat-text type="heading" heading-size="5" class="title">Experience<span class="color-brand">.</span></goat-text>
    <div class="experience-list">
      <div class="experience-item">
        <div class="role-details">
          <div class="logo">
            <goat-svg src="/assets/img/experience/servicenow.svg" title="ServiceNow" alt="ServiceNow"></goat-svg>
          </div>
          <div class="role">
            <goat-text type="heading" heading-size="3">Staff Software Engineer</goat-text>
            <goat-text color="secondary" type="body-compact">ServiceNow <goat-icon name="dot-mark" size=".625rem"></goat-icon> Full-time <goat-icon name="dot-mark" size=".625rem"></goat-icon> Hyderabad, India</goat-text>
            <goat-text color="secondary" type="body-compact">Dec 2017 - Present <goat-icon name="dot-mark" size=".625rem"></goat-icon> <span class="latest-experience"></span>+ yrs</goat-text>
          </div>
        </div>
        <div class="experience-details">
          <goat-text expressive>ServiceNow automates enterprise IT operations, creating a single system of record for all IT processes within an organization.</goat-text>
          <goat-text expressive>Worked on ServiceNow Platform and developed/enhanced products like Major Incident Management, On-Call Management, Task Communication Management, Universal Request, Microsoft Teams integrations etc.</goat-text>
        </div>
      </div>

      <goat-divider class="item-separator"></goat-divider>

      <div class="experience-item">
        <div class="role-details">
          <div class="logo">
            <img src="/assets/img/experience/kagami.webp" title="Kagami" alt="Kagami">
          </div>
          <div class="role">
            <goat-text type="heading" heading-size="3">Software Engineer</goat-text>
            <goat-text color="secondary" type="body-compact">Kagami India Pvt. Ltd. (StartUp) <goat-icon name="dot-mark" size=".625rem"></goat-icon> Full-time <goat-icon name="dot-mark" size=".625rem"></goat-icon> Hyderabad, India</goat-text>
            <goat-text color="secondary" type="body-compact">Jul 2016 - Dec 2017 <goat-icon name="dot-mark" size=".625rem"></goat-icon> 1 yr 6 mos</goat-text>
          </div>
        </div>
        <div class="experience-details">
          <goat-text expressive>Kagami, is a next generation ERP solution, which allows Business users to develop ERP modules, package them and deploy to cloud.</goat-text>
          <goat-text expressive>Developed user interfaces for products from scratch.</goat-text>
        </div>
      </div>

      <goat-divider class="item-separator"></goat-divider>

      <div class="experience-item">
        <div class="role-details">
          <div class="logo">
            <img src="/assets/img/experience/oracle.png" title="Oracle" alt="Oracle">
          </div>
          <div class="role">
            <goat-text type="heading" heading-size="3">Applications Engineer</goat-text>
            <goat-text color="secondary" type="body-compact">Oracle <goat-icon name="dot-mark" size=".625rem"></goat-icon> Full-time <goat-icon name="dot-mark" size=".625rem"></goat-icon> Bangalore, India</goat-text>
            <goat-text color="secondary" type="body-compact">Jul 2015 - Jun 2016 <goat-icon name="dot-mark" size=".625rem"></goat-icon> 1 yr</goat-text>
          </div>
        </div>
        <div class="experience-details">
          <goat-text expressive>Oracle Primavera P6 (Project Management Tool) application.</goat-text>
          <goat-text expressive>Revamped applet pages with modern UI technologies.</goat-text>
        </div>
      </div>

      <goat-divider class="item-separator"></goat-divider>

      <div class="experience-item">
        <div class="role-details">
          <div class="logo">
            <img src="/assets/img/experience/wipro.svg" title="Wipro" alt="Wipro">
          </div>
          <div class="role">
            <goat-text type="heading" heading-size="3">Senior Software Engineer</goat-text>
            <goat-text color="secondary" type="body-compact">Wipro <goat-icon name="dot-mark" size=".625rem"></goat-icon> Full-time <goat-icon name="dot-mark" size=".625rem"></goat-icon> Bangalore, India</goat-text>
            <goat-text color="secondary" type="body-compact">Jun 2012 - Jul 2015 <goat-icon name="dot-mark" size=".625rem"></goat-icon> 3 yrs 2 mos</goat-text>
          </div>
        </div>
        <div class="experience-details">
          <goat-text expressive>Oracle Primavera P6 (Project Management Tool).</goat-text>
          <goat-text expressive>Revamped applet pages with modern UI technologies.</goat-text>
        </div>
      </div>
    </div>
  </goat-container>

  <goat-container class="experience section">
    <goat-text type="heading" heading-size="5" class="title">Honors & awards<span class="color-brand">.</span></goat-text>

    <div class="award-item">
      <goat-text type="heading" heading-size="3">UTG LLama Award</goat-text>
      <goat-text color="secondary">Issued by ServiceNow <goat-icon name="dot-mark" size=".625rem"></goat-icon> Dec 2021</goat-text>
      <br/>
      <goat-text expressive>For helping customer in resolving release critical issue in short time period.</goat-text>
    </div>

    <goat-divider class="item-separator"></goat-divider>

    <div class="award-item">
      <goat-text type="heading" heading-size="3">Inspiring Performance</goat-text>
      <goat-text color="secondary">Issued by Wipro Technologies <goat-icon name="dot-mark" size=".625rem"></goat-icon> Feb 2015</goat-text>
      <br/>
      <goat-text expressive>This certificate is awarded for Responsive Micro site implementation and Best Performance in the project.</goat-text>
    </div>

    <goat-divider class="item-separator"></goat-divider>

    <div class="award-item">
      <goat-text type="heading" heading-size="3">Best Rookie</goat-text>
      <goat-text color="secondary">Issued by Wipro Technologies <goat-icon name="dot-mark" size=".625rem"></goat-icon> Aug 2014</goat-text>
      <br/>
      <goat-text expressive>This certificate is awarded for Quick learning and Best Performance in the project.</goat-text>
    </div>

    <goat-divider class="item-separator"></goat-divider>

    <div class="award-item">
      <goat-text type="heading" heading-size="3">Code Star</goat-text>
      <goat-text color="secondary">Issued by Wipro Technologies <goat-icon name="dot-mark" size=".625rem"></goat-icon> May 2014</goat-text>
      <br/>
      <goat-text expressive>This certificate is awarded for winning in 'CodeStrom' programming contest.</goat-text>
    </div>
  </goat-container>

  <goat-container class="showcase section">
    <goat-text type="heading" heading-size="5" class="title">Showcase<span class="color-success">.</span></goat-text>
    <goat-text>List of notable personal projects outside of work.</goat-text>
    <br/>
    <br/>
    <div class="showcase-item">
      <div class="project-details">
        <img class="logo" src="https://goatui.com/assets/img/logo.png" title="GOATUI" alt="GOATUI"/>
        <div class="details">
          <goat-text type="heading" heading-size="3">Goat UI</goat-text>
          <goat-text size="lg" type="paragraph">A lightweight web component library, build using stenciljs.</goat-text>
          <goat-text size="lg" type="paragraph">
            So you don't need to include any additional framework dependencies, You can simply import required component
            js, and right away start using it.
            Can easily be consumed by any other framework, like Vue, React, Angular, etc.
          </goat-text>
          <goat-button size="sm" href="https://goatui.com" color="dark" kind="simple" icon="launch">Read More</goat-button>
        </div>
      </div>
    </div>

    <goat-button class="view-all-projects color-success" icon="arrow--right" icon-end href="/project/">View all projects</goat-button>
  </goat-container>

</div>

<script type="text/javascript">
  function getAge(dateString) {
    const today = new Date();
    const birthDate = new Date(dateString);
    let age = today.getFullYear() - birthDate.getFullYear();
    const m = today.getMonth() - birthDate.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
      age--;
    }
    return age;
  }

  document.querySelector('.experience').innerText = getAge('06/20/2012');
  document.querySelector('.latest-experience').innerText = getAge('12/15/2017');
</script>
</Default>
