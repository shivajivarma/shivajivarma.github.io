---
import Default from '../layouts/Default.astro';
---

<Default
  keywords={['personal website', 'programmer', 'software engineering', 'web developer']}
  isRoot={true}
>
<div class="container-fluid">
  <div id="owl-index" class="owl-carousel owl-theme mt-3">
    <div class="item">
      <div class="row">
        <div class="col-md-12">
          <div class="text-shadow text-align-center leadText">Hello</div>
        </div>
      </div>
    </div>
    <div class="item">
      <div class="row">
        <div class="col-md-12">
          <div class="text-shadow text-align-center leadText"><i class="fa fa-code"></i> I'm a developer</div>
        </div>
      </div>
    </div>
    <div class="item">
      <div class="row">
        <div class="col-md-12">
          <div class="text-shadow text-align-center leadText"><i class="fa fa-heart"></i>'s to put computers to work <br/><i class="fa fa-cog fa-spin"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-md-12">
      <h1>Welcome to my website!</h1>
      <p class="lead">This site is centered around my blog, but contains lots of other content as well. You can use the links at the top, or else jump right to the various sections listed below:</p>
      <ul class="lead">
        <li class="padding-bottom-10px">
          <strong><a href="/blog/" title="Blog">Blog</a></strong><br>
          My running commentary on work and personal topics, including programming, web development, open source, standards, Android, playing cricket, stories, films, music, and anything else that pops into my head. Entries before 2013 are in my <a href="//shivajivarma.wordpress.com/" target="_blank" title="Archived Blog">Archived Blog</a>, slowly migrating it to this place.
        </li>
        <li class="padding-bottom-10px">
          <strong><a href="/about/" title="About">About</a></strong><br>
          Who I am. What I like to do. How I've been employed throughout my career.
        </li>
        <li class="padding-bottom-10px">
          <strong><a href="/project/code-base/" title="Code Base">Code Base</a></strong><br>
          It is a repository of programs, using which you can analyse, hack and learn basic programming.
        </li>
        <li class="padding-bottom-10px">
          <strong><a href="/project/" title="Projects">Projects</a></strong><br>
          Showcase of few of my works. Do check them out once.
        </li>
        <li class="padding-bottom-10px">
          <strong><a href="/blog/stories/" title="Short Stories">Short Stories</a></strong><br>
          I have habit of reading short and inspiring stories.
        </li>
      </ul>
      <p class="lead">Feel free to <a href="/about/#contact-hash" title="contact me">contact me</a> with questions or comments.</p>
    </div>
  </div>
</div>
</Default>
