---
import Blank from '../layouts/Blank.astro';
---

<Blank title="404" description="404!! This is not the web page you are looking for.">
  <style is:global>
    goat-empty-state {
      height: 100vh;
      width: 100vw;
    }
  </style>
  <goat-empty-state
    illustration="page"
    headline="404 : Page not found :("
    description="The requested page could not be found."
    action="Go to home page"
    action-url="/"
  ></goat-empty-state>
</Blank>
